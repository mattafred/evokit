                   <p className="text-7xl font-serif text-amber-500 mb-4">0</p>
                   <p className="text-xl font-bold tracking-widest uppercase opacity-40">Vis nécessaires</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

