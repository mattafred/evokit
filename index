      <section className="py-24 px-6 bg-amber-50/50">
        <div className="max-w-4xl mx-auto text-center space-y-8">
            <h2 className="text-4xl md:text-6xl font-serif">Offrez-lui un compagnon de route.</h2>
            <button className="bg-amber-900 text-white px-12 py-5 rounded-2xl font-bold text-xl hover:shadow-2xl transition-all hover:-translate-y-1">
