                    src={step.img} 
                    alt={step.title}
                    className={`absolute inset-0 w-full h-full object-cover transition-all duration-1000 ease-in-out ${
                      activeStep === idx ? 'opacity-100 scale-100 rotate-0' : 'opacity-0 scale-105 rotate-1'
